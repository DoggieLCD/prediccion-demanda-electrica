

import pandas as pd
from prophet import Prophet
import json
from prophet.serialize import model_to_json

# 1. Cargar y preparar los datos (asegurándonos de usar el mismo formato)
print("Cargando datos...")
df_sistema = pd.read_csv("demanda_sistemica_procesada.csv", 
                         sep=';', 
                         decimal=',', 
                         parse_dates=['fecha'])

df_prophet = df_sistema[['fecha', 'demanda_sistemica_mw']].copy()
df_prophet.rename(columns={'fecha': 'ds', 'demanda_sistemica_mw': 'y'}, inplace=True)
df_prophet.sort_values(by='ds', inplace=True)

# 2. Configurar y entrenar el modelo
# Usamos exactamente la misma configuración optimizada para la app
print("Entrenando el modelo... (Esto puede tomar unos segundos)")
modelo = Prophet(interval_width=0.95, 
                 yearly_seasonality=False, 
                 weekly_seasonality=True, 
                 daily_seasonality=False)

# Agregamos los feriados de Chile
modelo.add_country_holidays(country_name='CL')

# Entrenamos con los datos históricos
modelo.fit(df_prophet)

# 3. Exportar el modelo entrenado a formato JSON
nombre_archivo = 'modelo_prophet_entrenado.json'

with open(nombre_archivo, 'w') as fout:
    fout.write(model_to_json(modelo))

print(f"¡Éxito! El modelo ha sido guardado como '{nombre_archivo}'.")